      "source": [
        "# Show the Subreddit histogram and cumulative %\n",
        "\n",
        "import altair as alt\n",
        "\n",
        "counts = posts_df['Subreddit'].value_counts()\n",
        "counts_sorted = counts.sort_values(ascending=False).reset_index()\n",
        "counts_sorted.columns = [\"label\", \"count\"]\n",
        "counts_sorted[\"rank\"] = range(len(counts_sorted))\n",
        "counts_sorted[\"cum_pct\"] = counts_sorted[\"count\"].cumsum() / counts_sorted[\"count\"].sum() * 100\n",
        "\n",
        "max_count = counts_sorted[\"count\"].max()\n",
        "\n",
        "# Colors\n",
        "color_list = [\"coral\", \"mediumseagreen\", \"gold\", \"plum\"] + [\"steelblue\"] * (len(counts_sorted) - 4)\n",
        "counts_sorted[\"color\"] = color_list\n",
        "\n",
        "# Bar chart (left y-axis)\n",
        "bars = alt.Chart(counts_sorted).mark_bar(opacity=0.7).encode(\n",
        "    x=alt.X(\"rank:O\", axis=None, sort=None),\n",
        "    y=alt.Y(\"count:Q\", title=\"Count\", scale=alt.Scale(domain=[0, 60])),\n",
        "    color=alt.Color(\"color:N\", scale=None, legend=None)\n",
        ")\n",
        "\n",
        "# Cumulative % line (right y-axis)\n",
        "line = alt.Chart(counts_sorted).mark_line(color=\"black\", strokeWidth=2).encode(\n",
        "    x=alt.X(\"rank:O\", sort=None),\n",
        "    y=alt.Y(\"cum_pct:Q\", title=\"Cumulative %\", scale=alt.Scale(domain=[0, 120]))\n",
        ")\n",
        "\n",
        "# Combine with independent y scales\n",
        "chart = alt.layer(bars, line).resolve_scale(\n",
        "    y=\"independent\"\n",
        ").properties(\n",
        "    width=600,\n",
        "    height=400,\n",
        ")\n",
        "\n",
        "# Legend\n",
        "legend_df = counts_sorted.head(4).copy()\n",
        "legend_df[\"label\"] = \"r/\" + legend_df[\"label\"]\n",
        "legend_chart = alt.Chart(legend_df).mark_rect(size=200).encode(\n",
        "    y=alt.Y(\"label:N\", title=None, axis=alt.Axis(labelFontSize=12)),\n",
        "    color=alt.Color(\"color:N\", scale=None)\n",
        ").properties(title=\"Top Subreddit\", width=20, height=100)\n",
        "\n",
        "final = chart | legend_chart\n",
        "final"
      ]
    },
